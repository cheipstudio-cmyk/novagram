<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher foreground. Wraps the canonical 60x60 mark in a <group> that scales
  it up to fit a centered 80x80 area inside the 108x108 adaptive-icon canvas,
  so the logo sits well inside the 72x72 safe zone on circle masks and still
  reads at squircle/square masks.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:translateX="14"
        android:translateY="14"
        android:scaleX="1.333"
        android:scaleY="1.333">
        <path android:fillColor="#FFD9A85C" android:pathData="M44,12 C36,8 28,8 22,14 C16,20 14,26 14,30 C14,34 16,40 22,46 C28,52 36,52 44,48 L40,38 C36,40 32,42 28,39 C24,36 21,34 21,30 C21,26 24,24 28,21 C32,18 36,20 40,22 Z" />
        <path android:fillColor="#FFD9A85C" android:pathData="M37,18 L52,30 L37,42 Z" />
    </group>
</vector>
